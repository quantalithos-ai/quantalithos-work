{
  "store": {
    "adapter_kind": "in_memory",
    "transaction_timeout": "5s",
    "project_owner_uniqueness": "not_unique"
  },
  "boundary": {
    "max_command_body_bytes": 1048576,
    "max_page_limit": 100,
    "query_read_timeout": "2s"
  },
  "idempotency": {
    "command_retention": "24h",
    "event_dedup_retention": "7d",
    "reserved_record_max_age": "15m"
  },
  "projection": {
    "adapter_kind": "in_memory",
    "stale_threshold": "60s",
    "replace_scope": "project_projection_set"
  },
  "jobs": {
    "default_batch_size": 100,
    "max_parallelism": 1,
    "retry_limit": 3,
    "job_timeout": "300s"
  },
  "external": {
    "identity": {
      "adapter_kind": "fake"
    },
    "method_library": {
      "adapter_kind": "fake"
    },
    "source_work": {
      "adapter_kind": "fake"
    },
    "evidence": {
      "adapter_kind": "fake"
    },
    "process_timebox": {
      "adapter_kind": "fake"
    }
  },
  "outbox": {
    "publish_batch_size": 100,
    "publish_retry": {
      "max_attempts": 3,
      "base_delay": "1s",
      "max_delay": "30s"
    },
    "publisher": {
      "adapter_kind": "fake"
    }
  },
  "handoff": {
    "trace_target": {
      "adapter_kind": "fake"
    },
    "archive_target": {
      "adapter_kind": "fake"
    }
  },
  "features": {
    "derived_views_enabled": true,
    "advanced_search_enabled": false
  }
}
